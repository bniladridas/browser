# Copy this file to `.env` when configuring Firebase credentials (do not commit the filled `.env` file).
# macOS also needs `macos/Runner/GoogleService-Info.plist` alongside these vars; generate it with `flutterfire configure --platforms macos` or download it from your Firebase project.
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
